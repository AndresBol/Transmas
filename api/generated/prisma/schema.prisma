// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

// Models

enum Role {
  CLIENT
  PROFESSIONAL
  ADMIN
}

model User {
  id              Int      @id @default(autoincrement())
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  email           String   @unique @db.VarChar(150)
  passwordHash    String   @map("password_hash") @db.VarChar(255)
  phoneNumber     String   @unique @map("phone_number") @db.VarChar(30)
  role            Role     @default(CLIENT)
  isBlocked       Boolean  @default(false) @map("is_blocked")
  isActive        Boolean  @default(true) @map("is_active")
  createdOn       DateTime @default(now()) @map("created_on")
  createdById     Int?     @map("created_by")
  lastUpdatedOn   DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById Int?     @map("last_updated_by")

  createdBy     User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers  User[] @relation("UserCreatedBy")
  lastUpdatedBy User?  @relation("UserLastUpdatedBy", fields: [lastUpdatedById], references: [id])
  updatedUsers  User[] @relation("UserLastUpdatedBy")

  professionalProfile ProfessionalProfile? @relation("ProfessionalProfileProfessional")
  clientReservations  Reservation[]        @relation("ReservationClient")

  createdProfessionalProfiles             ProfessionalProfile[]            @relation("ProfessionalProfileCreatedBy")
  updatedProfessionalProfiles             ProfessionalProfile[]            @relation("ProfessionalProfileUpdatedBy")
  createdSpecialties                      Specialty[]                      @relation("SpecialtyCreatedBy")
  updatedSpecialties                      Specialty[]                      @relation("SpecialtyUpdatedBy")
  createdCategories                       Category[]                       @relation("CategoryCreatedBy")
  updatedCategories                       Category[]                       @relation("CategoryUpdatedBy")
  createdTransportationServices           TransportationService[]          @relation("TransportationServiceCreatedBy")
  updatedTransportationServices           TransportationService[]          @relation("TransportationServiceUpdatedBy")
  createdProfessionalProfileSpecialties   ProfessionalProfileSpecialty[]   @relation("ProfessionalProfileSpecialtyCreatedBy")
  updatedProfessionalProfileSpecialties   ProfessionalProfileSpecialty[]   @relation("ProfessionalProfileSpecialtyUpdatedBy")
  createdTransportationServiceSpecialties TransportationServiceSpecialty[] @relation("TransportationServiceSpecialtyCreatedBy")
  updatedTransportationServiceSpecialties TransportationServiceSpecialty[] @relation("TransportationServiceSpecialtyUpdatedBy")
  createdReservations                     Reservation[]                    @relation("ReservationCreatedBy")
  updatedReservations                     Reservation[]                    @relation("ReservationUpdatedBy")
  createdServiceRatings                   ServiceRating[]                  @relation("ServiceRatingCreatedBy")
  updatedServiceRatings                   ServiceRating[]                  @relation("ServiceRatingUpdatedBy")
  createdTimelines                        Timeline[]                       @relation("TimelineCreatedBy")
  updatedTimelines                        Timeline[]                       @relation("TimelineUpdatedBy")
  createdStatuses                         Status[]                         @relation("StatusCreatedBy")
  updatedStatuses                         Status[]                         @relation("StatusUpdatedBy")

  @@map("user")
}

model ProfessionalProfile {
  id                Int      @id @default(autoincrement())
  professionalTitle String   @map("professional_title") @db.VarChar(150)
  description       String   @db.VarChar(500)
  experienceYears   Int      @map("experience_years")
  baseRate          Decimal  @map("base_rate") @db.Decimal(10, 2)
  isAvailable       Boolean  @map("is_available")
  profilePictureUrl String   @default("image-not-found.jpg") @map("profile_picture_url") @db.VarChar(255)
  professionalId    Int      @unique @map("professional_id")
  districtId        Int      @map("district_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdOn         DateTime @default(now()) @map("created_on")
  createdById       Int      @map("created_by")
  lastUpdatedOn     DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById   Int      @map("last_updated_by")

  professional  User     @relation("ProfessionalProfileProfessional", fields: [professionalId], references: [id])
  district      District @relation(fields: [districtId], references: [id])
  createdBy     User     @relation("ProfessionalProfileCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy User     @relation("ProfessionalProfileUpdatedBy", fields: [lastUpdatedById], references: [id])

  specialties ProfessionalProfileSpecialty[]
  services    TransportationService[]

  @@map("professional_profile")
}

model Specialty {
  id              Int      @id @default(autoincrement())
  name            String   @unique @db.VarChar(100)
  description     String   @db.VarChar(255)
  isAvailable     Boolean  @map("is_available")
  isActive        Boolean  @default(true) @map("is_active")
  createdOn       DateTime @default(now()) @map("created_on")
  createdById     Int      @map("created_by")
  lastUpdatedOn   DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById Int      @map("last_updated_by")

  createdBy     User @relation("SpecialtyCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy User @relation("SpecialtyUpdatedBy", fields: [lastUpdatedById], references: [id])

  professionalProfiles   ProfessionalProfileSpecialty[]
  transportationServices TransportationServiceSpecialty[]

  @@map("specialty")
}

model Category {
  id              Int      @id @default(autoincrement())
  name            String   @unique @db.VarChar(100)
  description     String   @db.VarChar(255)
  isAvailable     Boolean  @map("is_available")
  isActive        Boolean  @default(true) @map("is_active")
  createdOn       DateTime @default(now()) @map("created_on")
  createdById     Int      @map("created_by")
  lastUpdatedOn   DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById Int      @map("last_updated_by")

  createdBy     User @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy User @relation("CategoryUpdatedBy", fields: [lastUpdatedById], references: [id])

  transportationServices TransportationService[]

  @@map("category")
}

model TransportationService {
  id                    Int      @id @default(autoincrement())
  name                  String   @db.VarChar(150)
  description           String   @db.VarChar(500)
  price                 Decimal  @db.Decimal(10, 2)
  estimatedDuration     Int      @map("estimated_duration")
  isAvailable           Boolean  @map("is_available")
  professionalProfileId Int      @map("professional_profile_id")
  categoryId            Int      @map("category_id")
  isActive              Boolean  @default(true) @map("is_active")
  createdOn             DateTime @default(now()) @map("created_on")
  createdById           Int      @map("created_by")
  lastUpdatedOn         DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById       Int      @map("last_updated_by")

  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id])
  category            Category            @relation(fields: [categoryId], references: [id])
  createdBy           User                @relation("TransportationServiceCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy       User                @relation("TransportationServiceUpdatedBy", fields: [lastUpdatedById], references: [id])

  specialties  TransportationServiceSpecialty[]
  reservations Reservation[]

  @@map("transportation_service")
}

model ProfessionalProfileSpecialty {
  professionalProfileId Int      @map("professional_profile_id")
  specialtyId           Int      @map("specialty_id")
  isActive              Boolean  @default(true) @map("is_active")
  createdOn             DateTime @default(now()) @map("created_on")
  createdById           Int      @map("created_by")
  lastUpdatedOn         DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById       Int      @map("last_updated_by")

  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  specialty           Specialty           @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  createdBy           User                @relation("ProfessionalProfileSpecialtyCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy       User                @relation("ProfessionalProfileSpecialtyUpdatedBy", fields: [lastUpdatedById], references: [id])

  @@id([professionalProfileId, specialtyId])
  @@map("professional_profile_specialty")
}

model TransportationServiceSpecialty {
  transportationServiceId Int      @map("transportation_service_id")
  specialtyId             Int      @map("specialty_id")
  isActive                Boolean  @default(true) @map("is_active")
  createdOn               DateTime @default(now()) @map("created_on")
  createdById             Int      @map("created_by")
  lastUpdatedOn           DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById         Int      @map("last_updated_by")

  transportationService TransportationService @relation(fields: [transportationServiceId], references: [id], onDelete: Cascade)
  specialty             Specialty             @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  createdBy             User                  @relation("TransportationServiceSpecialtyCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy         User                  @relation("TransportationServiceSpecialtyUpdatedBy", fields: [lastUpdatedById], references: [id])

  @@id([transportationServiceId, specialtyId])
  @@map("transportation_service_specialty")
}

model Reservation {
  id                      Int      @id @default(autoincrement())
  description             String   @db.VarChar(500)
  pickupLatitude          Decimal  @map("pickup_latitude") @db.Decimal(10, 7)
  pickupLongitude         Decimal  @map("pickup_longitude") @db.Decimal(11, 7)
  pickupAddress           String   @map("pickup_address") @db.VarChar(255)
  dropoffLatitude         Decimal  @map("dropoff_latitude") @db.Decimal(10, 7)
  dropoffLongitude        Decimal  @map("dropoff_longitude") @db.Decimal(11, 7)
  dropoffAddress          String   @map("dropoff_address") @db.VarChar(255)
  passengerCount          Int      @map("passenger_count")
  startDate               DateTime @map("start_date")
  endDate                 DateTime @map("end_date")
  professionalResponse    String?  @map("professional_response") @db.VarChar(500)
  quoteAmount             Decimal? @map("quote_amount") @db.Decimal(10, 2)
  clientId                Int      @map("client_id")
  transportationServiceId Int      @map("transportation_service_id")
  pickupDistrictId        Int      @map("pickup_district_id")
  dropoffDistrictId       Int      @map("dropoff_district_id")
  statusId                Int      @map("status_id")
  isActive                Boolean  @default(true) @map("is_active")
  createdOn               DateTime @default(now()) @map("created_on")
  createdById             Int      @map("created_by")
  lastUpdatedOn           DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById         Int      @map("last_updated_by")

  client                User                  @relation("ReservationClient", fields: [clientId], references: [id])
  transportationService TransportationService @relation(fields: [transportationServiceId], references: [id])
  pickupDistrict        District              @relation("ReservationPickupDistrict", fields: [pickupDistrictId], references: [id])
  dropoffDistrict       District              @relation("ReservationDropoffDistrict", fields: [dropoffDistrictId], references: [id])
  status                Status                @relation(fields: [statusId], references: [id])
  createdBy             User                  @relation("ReservationCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy         User                  @relation("ReservationUpdatedBy", fields: [lastUpdatedById], references: [id])

  serviceRating ServiceRating?
  timelines     Timeline[]

  @@map("reservation")
}

model ServiceRating {
  id              Int      @id @default(autoincrement())
  rating          Int
  description     String?  @db.VarChar(500)
  reservationId   Int      @unique @map("reservation_id")
  isActive        Boolean  @default(true) @map("is_active")
  createdOn       DateTime @default(now()) @map("created_on")
  createdById     Int      @map("created_by")
  lastUpdatedOn   DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById Int      @map("last_updated_by")

  reservation   Reservation @relation(fields: [reservationId], references: [id])
  createdBy     User        @relation("ServiceRatingCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy User        @relation("ServiceRatingUpdatedBy", fields: [lastUpdatedById], references: [id])

  @@map("service_rating")
}

model Timeline {
  id              Int      @id @default(autoincrement())
  subject         String   @db.VarChar(150)
  description     String   @db.VarChar(500)
  reservationId   Int      @map("reservation_id")
  isActive        Boolean  @default(true) @map("is_active")
  createdOn       DateTime @default(now()) @map("created_on")
  createdById     Int?     @map("created_by")
  lastUpdatedOn   DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById Int?     @map("last_updated_by")

  reservation   Reservation @relation(fields: [reservationId], references: [id])
  createdBy     User?       @relation("TimelineCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy User?       @relation("TimelineUpdatedBy", fields: [lastUpdatedById], references: [id])

  @@map("timeline")
}

model Status {
  id              Int      @id @default(autoincrement())
  name            String   @unique @db.VarChar(100)
  isActive        Boolean  @default(true) @map("is_active")
  createdOn       DateTime @default(now()) @map("created_on")
  createdById     Int      @map("created_by")
  lastUpdatedOn   DateTime @default(now()) @updatedAt @map("last_updated_on")
  lastUpdatedById Int      @map("last_updated_by")

  createdBy     User @relation("StatusCreatedBy", fields: [createdById], references: [id])
  lastUpdatedBy User @relation("StatusUpdatedBy", fields: [lastUpdatedById], references: [id])

  reservations Reservation[]

  @@map("status")
}

model Province {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  cantons Canton[]

  @@map("province")
}

model Canton {
  id         Int    @id @default(autoincrement())
  name       String @db.VarChar(100)
  provinceId Int    @map("province_id")

  province  Province   @relation(fields: [provinceId], references: [id])
  districts District[]

  @@map("canton")
}

model District {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(100)
  cantonId Int    @map("canton_id")

  canton               Canton                @relation(fields: [cantonId], references: [id])
  professionalProfiles ProfessionalProfile[]
  pickupReservations   Reservation[]         @relation("ReservationPickupDistrict")
  dropoffReservations  Reservation[]         @relation("ReservationDropoffDistrict")

  @@map("district")
}
